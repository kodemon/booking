{
  "$schema": "https://api.cerbos.dev/v0.51.0/cerbos/policy/v1/Policy.schema.json",
  "apiVersion": "api.cerbos.dev/v1",
  "resourcePolicy": {
    "resource": "account",
    "version": "default",
    "rules": [
      {
        "actions": ["create"],
        "effect": "EFFECT_ALLOW",
        "roles": ["user"]
      },
      {
        "actions": ["view"],
        "effect": "EFFECT_ALLOW",
        "roles": ["user"]
      }
    ]
  }
}